# Copy this file to .env and fill in your real values
# NEVER commit .env to GitHub - it's in .gitignore

# Supabase - get from supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# JWT - make this a long random string, anything you want
JWT_SECRET=make-this-something-long-and-random-like-whispr2024secretkey

# Resend - get from resend.com → API Keys
RESEND_API_KEY=re_your_key_here

# Anthropic - get from console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# App
PORT=3000
FRONTEND_URL=https://yourusername.github.io
